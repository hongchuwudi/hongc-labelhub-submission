        <mxCell id="db-check" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#3b82f6;fontSize=10;arcSize=10;align=center;" value="&lt;b&gt;MySQL 兜底校验&lt;/b&gt;&lt;br&gt;&lt;br&gt;WHERE claimed_items &lt; grab_limit&lt;br&gt;&lt;br&gt;防止：Redis 锁超时 + 网络延迟&lt;br&gt;导致的边界超发" vertex="1">
