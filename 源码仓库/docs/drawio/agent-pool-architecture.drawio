<mxGraphModel adaptiveColors="auto"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="t" value="Agent 池架构图 — AgentPool + Agent 生命周期" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;fontColor=#262626;" vertex="1" parent="1"><mxGeometry x="150" y="10" width="700" height="40" as="geometry"/></mxCell><mxCell id="mq-bg" value="&lt;b&gt;📨 消息层 — RabbitMQ&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7E6;strokeColor=#FFD591;strokeWidth=2;verticalAlign=top;fontSize=12;fontColor=#D4380D;align=center;spacingTop=4;" vertex="1" parent="1"><mxGeometry x="20" y="60" width="960" height="70" as="geometry"/></mxCell><mxCell id="mq-queue" value="labelhub.ai.review (持久化队列)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#FA8C16;fontSize=10;fontColor=#D4380D;align=center;" vertex="1" parent="1"><mxGeometry x="40" y="82" width="200" height="30" as="geometry"/></mxCell><mxCell id="mq-producer" value="Publisher: create_result()&#10;检测 ai_agent_id → publish" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F6FFED;strokeColor=#52C41A;fontSize=9;fontColor=#389E0D;align=center;" vertex="1" parent="1"><mxGeometry x="280" y="82" width="180" height="30" as="geometry"/></mxCell><mxCell id="mq-msg" value="消息体: {task_id, result_id, item_id}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#BFBFBF;fontSize=8;fontColor=#8C8C8C;align=center;" vertex="1" parent="1"><mxGeometry x="500" y="82" width="200" height="30" as="geometry"/></mxCell><mxCell id="mq-props" value="delivery_mode=2 (持久化)&#10;手动 ACK / NACK+requeue" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#BFBFBF;fontSize=8;fontColor=#8C8C8C;align=center;" vertex="1" parent="1"><mxGeometry x="740" y="82" width="220" height="30" as="geometry"/></mxCell><mxCell id="e-mq1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeWidth=1;strokeColor=#D9D9D9;" edge="1" parent="1" source="mq-queue" target="mq-producer"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e-mq2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeWidth=1;strokeColor=#D9D9D9;" edge="1" parent="1" source="mq-producer" target="mq-msg"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e-mq3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeWidth=1;strokeColor=#D9D9D9;" edge="1" parent="1" source="mq-msg" target="mq-props"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="worker-bg" value="&lt;b&gt;⚙️ Worker 层 — ai_worker.py&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F4FF;strokeColor=#ADCBFF;strokeWidth=2;verticalAlign=top;fontSize=12;fontColor=#1677FF;align=center;spacingTop=4;" vertex="1" parent="1"><mxGeometry x="20" y="150" width="960" height="60" as="geometry"/></mxCell><mxCell id="worker-consume" value="consume(AI_REVIEW_QUEUE, handle_message)&#10;prefetch=1（公平分发）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1677FF;fontSize=9;fontColor=#1677FF;align=center;" vertex="1" parent="1"><mxGeometry x="40" y="166" width="240" height="30" as="geometry"/></mxCell><mxCell id="worker-handle" value="handle_message():&#10;JSON 解码 → 查 DB 确认 ai_agent_id&#10;→ pool.submit() → basic_ack()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1677FF;fontSize=9;fontColor=#1677FF;align=center;" vertex="1" parent="1"><mxGeometry x="320" y="166" width="320" height="30" as="geometry"/></mxCell><mxCell id="worker-retry" value="连接断线 → 每 5s 重试" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF1F0;strokeColor=#FF4D4F;fontSize=9;fontColor=#CF1322;align=center;" vertex="1" parent="1"><mxGeometry x="680" y="166" width="200" height="30" as="geometry"/></mxCell><mxCell id="e-w1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeWidth=1;strokeColor=#D9D9D9;" edge="1" parent="1" source="worker-consume" target="worker-handle"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e-w2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeWidth=1;strokeColor=#D9D9D9;" edge="1" parent="1" source="worker-handle" target="worker-retry"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="pool-bg" value="&lt;b&gt;🧠 线程池层 — AgentPool (单例)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F6FFED;strokeColor=#B7EB8F;strokeWidth=2;verticalAlign=top;fontSize=12;fontColor=#389E0D;align=center;spacingTop=4;" vertex="1" parent="1"><mxGeometry x="20" y="230" width="510" height="330" as="geometry"/></mxCell><mxCell id="pool-executor" value="executor = ThreadPoolExecutor(max_workers=POOL_SIZE)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#52C41A;fontSize=9;fontColor=#389E0D;align=center;" vertex="1" parent="1"><mxGeometry x="40" y="265" width="470" height="24" as="geometry"/></mxCell><mxCell id="pool-agents" value="agents: dict[int, Agent]&#10;{id → Agent(...)}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#52C41A;fontSize=9;fontColor=#389E0D;align=center;" vertex="1" parent="1"><mxGeometry x="40" y="300" width="470" height="24" as="geometry"/></mxCell><mxCell id="pool-lock" value="_lock = threading.Lock()  保护 agents 并发安全" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFBE6;strokeColor=#FFE58F;fontSize=9;fontColor=#AD6800;align=center;" vertex="1" parent="1"><mxGeometry x="40" y="335" width="470" height="24" as="geometry"/></mxCell><mxCell id="pool-pending" value="_pending_count: int  计数排队+执行中任务" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFBE6;strokeColor=#FFE58F;fontSize=9;fontColor=#AD6800;align=center;" vertex="1" parent="1"><mxGeometry x="40" y="370" width="470" height="24" as="geometry"/></mxCell><mxCell id="pool-methods-title" value="方法:" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;fontColor=#262626;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="405" width="60" height="20" as="geometry"/></mxCell><mxCell id="pool-start" value="start() — 幂等初始化: 查 DB 加载 AiAgent → 创建 Agent → 建 ThreadPoolExecutor" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F6FFED;strokeColor=#52C41A;fontSize=9;fontColor=#389E0D;align=left;spacingLeft=4;" vertex="1" parent="1"><mxGeometry x="40" y="425" width="470" height="22" as="geometry"/></mxCell><mxCell id="pool-submit" value="submit(task_id, result_id, item_id) — 查 Agent → executor.submit(agent.run) → done_callback" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F6FFED;strokeColor=#52C41A;fontSize=9;fontColor=#389E0D;align=left;spacingLeft=4;" vertex="1" parent="1"><mxGeometry x="40" y="452" width="470" height="22" as="geometry"/></mxCell><mxCell id="pool-reload" value="reload() — 热重载: 新增 / 更新 idle 态 / 跳过 busy 删除" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F6FFED;strokeColor=#52C41A;fontSize=9;fontColor=#389E0D;align=left;spacingLeft=4;" vertex="1" parent="1"><mxGeometry x="40" y="479" width="470" height="22" as="geometry"/></mxCell><mxCell id="pool-get-status" value="get_status() — 返回 {agents: [...], pool_size, busy_count, pending_count}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F6FFED;strokeColor=#52C41A;fontSize=9;fontColor=#389E0D;align=left;spacingLeft=4;" vertex="1" parent="1"><mxGeometry x="40" y="506" width="470" height="22" as="geometry"/></mxCell><mxCell id="pool-shutdown" value="shutdown() — executor.shutdown(wait=True) 优雅关闭" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF1F0;strokeColor=#FF4D4F;fontSize=9;fontColor=#CF1322;align=left;spacingLeft=4;" vertex="1" parent="1"><mxGeometry x="40" y="533" width="470" height="22" as="geometry"/></mxCell><mxCell id="agent-instances-title" value="Agent 实例" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=12;fontColor=#389E0D;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="560" y="240" width="180" height="20" as="geometry"/></mxCell><mxCell id="agent1" value="&lt;b&gt;Agent #1&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px&quot;&gt;gpt-4o&lt;br&gt;状态: idle&lt;br&gt;维度: 相关/准确/合规&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D9D9D9;fontSize=10;" vertex="1" parent="1"><mxGeometry x="560" y="268" width="180" height="58" as="geometry"/></mxCell><mxCell id="agent2" value="&lt;b&gt;Agent #2&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px&quot;&gt;gpt-4o-mini&lt;br&gt;状态: busy (审核中)&lt;br&gt;维度: 相关/准确&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7E6;strokeColor=#FA8C16;fontSize=10;fontColor=#D4380D;" vertex="1" parent="1"><mxGeometry x="560" y="338" width="180" height="58" as="geometry"/></mxCell><mxCell id="agent3" value="&lt;b&gt;Agent #3&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px&quot;&gt;gpt-4o&lt;br&gt;状态: idle&lt;br&gt;维度: 安全/格式/准确&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D9D9D9;fontSize=10;" vertex="1" parent="1"><mxGeometry x="560" y="408" width="180" height="58" as="geometry"/></mxCell><mxCell id="agent-dots" value="..." style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=" vertex="1" parent="1"><mxGeometry x="560" y="477" width="180" height="20" as="geometry"/></mxCell><mxCell id="agent-prop1" value="零冷启动 — Agent 常驻内存，持有独立 OpenAI Client" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFBE6;strokeColor=#FFE58F;fontSize=8;fontColor=#AD6800;align=center;" vertex="1" parent="1"><mxGeometry x="560" y="505" width="180" height="24" as="geometry"/></mxCell><mxCell id="agent-prop2" value="busy 态不被 reload 打断&#10;删除时也跳过" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFBE6;strokeColor=#FFE58F;fontSize=8;fontColor=#AD6800;align=center;" vertex="1" parent="1"><mxGeometry x="560" y="537" width="180" height="24" as="geometry"/></mxCell><mxCell id="run-bg" value="&lt;b&gt;🔄 Agent.run() 生命周期 (在独立线程中执行)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9F0FF;strokeColor=#D3ADF7;strokeWidth=2;verticalAlign=top;fontSize=12;fontColor=#722ED1;align=center;spacingTop=4;" vertex="1" parent="1"><mxGeometry x="20" y="585" width="960" height="380" as="geometry"/></mxCell><mxCell id="run-1" value="1. status = &quot;busy&quot;, 记录 start_time" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D9D9D9;fontSize=9;spacingLeft=4;" vertex="1" parent="1"><mxGeometry x="40" y="620" width="440" height="26" as="geometry"/></mxCell><mxCell id="run-2" value="2. 查 DB: LabelTask + DatasetItem + LabelResult" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D9D9D9;fontSize=9;spacingLeft=4;" vertex="1" parent="1"><mxGeometry x="40" y="654" width="440" height="26" as="geometry"/></mxCell><mxCell id="run-3" value="3. transit(result → ai_reviewing) + 审计日志 + append_flow" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D9D9D9;fontSize=9;spacingLeft=4;" vertex="1" parent="1"><mxGeometry x="40" y="688" width="440" height="26" as="geometry"/></mxCell><mxCell id="run-4" value="4. 构建 Prompt: 替换 {dimensions} {task} {item} {result}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D9D9D9;fontSize=9;spacingLeft=4;" vertex="1" parent="1"><mxGeometry x="40" y="722" width="440" height="26" as="geometry"/></mxCell><mxCell id="run-5-title" value="5. LLM 调用 (最多重试 3 次)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF7E6;strokeColor=#FA8C16;fontSize=9;spacingLeft=4;fontColor=#D4380D;" vertex="1" parent="1"><mxGeometry x="40" y="756" width="440" height="26" as="geometry"/></mxCell><mxCell id="run-6" value="6. 写入 AiReview (维度分 / 总体分 / 判定 / Prompt 原文 / 耗时)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F6FFED;strokeColor=#52C41A;fontSize=9;spacingLeft=4;fontColor=#389E0D;" vertex="1" parent="1"><mxGeometry x="40" y="790" width="440" height="26" as="geometry"/></mxCell><mxCell id="run-7" value="7. 更新 LabelResult.ai_scores JSON 列" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F6FFED;strokeColor=#52C41A;fontSize=9;spacingLeft=4;fontColor=#389E0D;" vertex="1" parent="1"><mxGeometry x="40" y="824" width="440" height="26" as="geometry"/></mxCell><mxCell id="run-8" value="8. 状态机: verdict==reject → REJECTED / pass|human_review → REVIEW" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F6FFED;strokeColor=#52C41A;fontSize=9;spacingLeft=4;fontColor=#389E0D;" vertex="1" parent="1"><mxGeometry x="40" y="858" width="440" height="26" as="geometry"/></mxCell><mxCell id="run-9" value="9. 审计日志 (action=ai_reject / ai_to_review) + append_flow" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D9D9D9;fontSize=9;spacingLeft=4;" vertex="1" parent="1"><mxGeometry x="40" y="892" width="440" height="26" as="geometry"/></mxCell><mxCell id="run-10" value="10. finally: status = &quot;idle&quot;, db.close()" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#BFBFBF;fontSize=9;spacingLeft=4;fontColor=#8C8C8C;" vertex="1" parent="1"><mxGeometry x="40" y="926" width="440" height="26" as="geometry"/></mxCell><mxCell id="e-run1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeWidth=1.5;strokeColor=#722ED1;" edge="1" parent="1" source="run-1" target="run-2"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e-run2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeWidth=1.5;strokeColor=#722ED1;" edge="1" parent="1" source="run-2" target="run-3"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e-run3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeWidth=1.5;strokeColor=#722ED1;" edge="1" parent="1" source="run-3" target="run-4"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e-run4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeWidth=1.5;strokeColor=#722ED1;" edge="1" parent="1" source="run-4" target="run-5-title"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e-run5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeWidth=1.5;strokeColor=#722ED1;" edge="1" parent="1" source="run-5-title" target="run-6"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e-run6" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeWidth=1.5;strokeColor=#722ED1;" edge="1" parent="1" source="run-6" target="run-7"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e-run7" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeWidth=1.5;strokeColor=#722ED1;" edge="1" parent="1" source="run-7" target="run-8"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e-run8" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeWidth=1.5;strokeColor=#722ED1;" edge="1" parent="1" source="run-8" target="run-9"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e-run9" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeWidth=1.5;strokeColor=#722ED1;" edge="1" parent="1" source="run-9" target="run-10"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="llm-detail" value="&lt;b&gt;LLM 调用细节&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#FA8C16;fontSize=10;fontColor=#D4380D;align=center;verticalAlign=top;spacingTop=4;" vertex="1" parent="1"><mxGeometry x="520" y="615" width="440" height="180" as="geometry"/></mxCell><mxCell id="llm-client" value="client = OpenAI(api_key=..., base_url=...)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF7E6;strokeColor=#FA8C16;fontSize=8;fontColor=#D4380D;spacingLeft=4;" vertex="1" parent="1"><mxGeometry x="535" y="645" width="410" height="22" as="geometry"/></mxCell><mxCell id="llm-request" value="POST chat.completions&#10;model=, temperature=0, messages=[system_prompt, user_instruction+schema_hint]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF7E6;strokeColor=#FA8C16;fontSize=8;fontColor=#D4380D;spacingLeft=4;" vertex="1" parent="1"><mxGeometry x="535" y="675" width="410" height="28" as="geometry"/></mxCell><mxCell id="llm-json" value="JSON 提取: 优先 ```json``` 代码块 → 裸 {} 对象" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D9D9D9;fontSize=8;spacingLeft=4;" vertex="1" parent="1"><mxGeometry x="535" y="708" width="410" height="22" as="geometry"/></mxCell><mxCell id="llm-validate" value="Pydantic 校验: ReviewResult.model_validate()&#10;dimensions: [{name, score(0-1), reason}], verdict∈{pass,reject,human_review}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F6FFED;strokeColor=#52C41A;fontSize=8;fontColor=#389E0D;spacingLeft=4;" vertex="1" parent="1"><mxGeometry x="535" y="738" width="410" height="28" as="geometry"/></mxCell><mxCell id="llm-retry" value="校验失败: 注入错误信息修正 Prompt 重试 (最多 3 次)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF1F0;strokeColor=#FF4D4F;fontSize=8;fontColor=#CF1322;spacingLeft=4;" vertex="1" parent="1"><mxGeometry x="535" y="771" width="410" height="22" as="geometry"/></mxCell><mxCell id="db-bg" value="&lt;b&gt;🗄️ 数据库表&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0F5FF;strokeColor=#ADCBFF;strokeWidth=2;verticalAlign=top;fontSize=12;fontColor=#1677FF;align=center;spacingTop=4;" vertex="1" parent="1"><mxGeometry x="520" y="815" width="440" height="150" as="geometry"/></mxCell><mxCell id="db-ai-agents" value="ai_agents — Agent 配置 (model/dimensions/prompt)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D9D9D9;fontSize=8;spacingLeft=4;" vertex="1" parent="1"><mxGeometry x="535" y="845" width="410" height="22" as="geometry"/></mxCell><mxCell id="db-ai-review" value="ai_reviews — 审核记录 (verdict/summary/dimensions/overall_score/prompt_template/duration)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E6F4FF;strokeColor=#1677FF;fontSize=8;spacingLeft=4;fontColor=#1677FF;" vertex="1" parent="1"><mxGeometry x="535" y="875" width="410" height="22" as="geometry"/></mxCell><mxCell id="db-tasks" value="tasks — 绑定 ai_agent_id" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D9D9D9;fontSize=8;spacingLeft=4;" vertex="1" parent="1"><mxGeometry x="535" y="905" width="410" height="22" as="geometry"/></mxCell><mxCell id="db-results" value="label_results — ai_scores (JSON) + status (状态机)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F6FFED;strokeColor=#52C41A;fontSize=8;spacingLeft=4;fontColor=#389E0D;" vertex="1" parent="1"><mxGeometry x="535" y="935" width="410" height="22" as="geometry"/></mxCell><mxCell id="e-pool-submit" value="pool.submit()" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeWidth=2;strokeColor=#52C41A;fontSize=9;fontColor=#389E0D;fontStyle=1;" edge="1" parent="1" source="pool-submit" target="agent1"><mxGeometry relative="1" as="geometry"><mxPoint x="510" y="463" as="sourcePoint"/><mxPoint x="560" y="297" as="targetPoint"/></mxGeometry></mxCell><mxCell id="e-worker-pool" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeWidth=2;strokeColor=#1677FF;" edge="1" parent="1" source="worker-handle" target="pool-bg"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e-mq-worker" value="handle_message" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeWidth=2;strokeColor=#FA8C16;fontSize=9;fontColor=#D4380D;" edge="1" parent="1" source="mq-queue" target="worker-bg"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="arrow-pool-run" value="executor.submit(agent.run, ...)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeWidth=2;strokeColor=#722ED1;fontSize=9;fontColor=#722ED1;fontStyle=1;" edge="1" parent="1" source="pool-bg" target="run-bg"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e-run-db" value="读/写" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeWidth=1.5;strokeColor=#1677FF;fontSize=9;fontColor=#1677FF;" edge="1" parent="1" source="run-2" target="db-bg"><mxGeometry relative="1" as="geometry"><mxPoint x="260" y="680" as="sourcePoint"/><mxPoint x="740" y="815" as="targetPoint"/></mxGeometry></mxCell></root></mxGraphModel>
