        <mxCell id="p2-fail-label" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=9;fontColor=#ef4444;fontStyle=1;" value="过期/无效" vertex="1">
          <mxGeometry height="15" width="55" x="410" y="482" as="geometry" />
        </mxCell>
        <mxCell id="p2-refresh-flow" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#ef4444;fontSize=9;arcSize=8;" value="&lt;b&gt;Axios 响应拦截器&lt;/b&gt;&lt;br&gt;catch 401 → 取 refresh_token&lt;br&gt;POST /api/auth/refresh&lt;br&gt;→ 新 access_token + 新 refresh_token&lt;br&gt;→ 更新 store + localStorage&lt;br&gt;→ 重放原请求" vertex="1">
          <mxGeometry height="90" width="200" x="200" y="565" as="geometry" />
        </mxCell>
        <mxCell id="p2-a4" edge="1" parent="1" style="endArrow=classic;html=1;strokeColor=#ef4444;strokeWidth=2;">
