          <mxGeometry relative="1" as="geometry">
            <mxPoint x="300" y="655" as="sourcePoint" />
            <mxPoint x="300" y="700" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="p2-a5-label" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=9;fontColor=#ef4444;" value="refresh 也失败" vertex="1">
          <mxGeometry height="15" width="65" x="305" y="665" as="geometry" />
        </mxCell>
        <mxCell id="p2-logout" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#ef4444;strokeWidth=2;fontSize=10;arcSize=12;" value="清除 store + localStorage&lt;br&gt;跳转 /login" vertex="1">
          <mxGeometry height="40" width="170" x="215" y="700" as="geometry" />
        </mxCell>
        <mxCell id="p3-label" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=14;fontStyle=1;fontColor=#1a1a2e;" value="3. 角色鉴权 (依赖注入链)" vertex="1">
          <mxGeometry height="25" width="250" x="470" y="565" as="geometry" />
        </mxCell>
        <mxCell id="p3-flow" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FAFB;strokeColor=#d1d5db;arcSize=5;" value="" vertex="1">
          <mxGeometry height="140" width="270" x="470" y="600" as="geometry" />
        </mxCell>
        <mxCell id="p3-chain" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=9;fontColor=#6b7280;spacingLeft=6;" value="&lt;b&gt;FastAPI Depends() 注入链&lt;/b&gt;&lt;br&gt;&lt;br&gt;① get_current_user(token)&lt;br&gt;    ├─ 验证 JWT 签名 + 过期时间&lt;br&gt;    └─ 从 DB 查用户（若缓存未命中）&lt;br&gt;&lt;br&gt;② require_role(user, &quot;owner&quot;)&lt;br&gt;    └─ user.role in allowed_roles ?&lt;br&gt;       ├─ 是 → 继续&lt;br&gt;       └─ 否 → 403 Forbidden" vertex="1">
          <mxGeometry height="125" width="254" x="478" y="608" as="geometry" />
        </mxCell>
        <mxCell id="p3-example" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;arcSize=5;" value="" vertex="1">
          <mxGeometry height="140" width="270" x="780" y="600" as="geometry" />
        </mxCell>
        <mxCell id="p3-code" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=10;fontColor=#FFFFFF;spacingLeft=8;fontFamily=monospace;" value="&lt;font color=&quot;#10b981&quot;&gt;# 路由示例&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#9ca3af&quot;&gt;@router.get(&quot;/tasks&quot;)&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#f59e0b&quot;&gt;async def &lt;/font&gt;&lt;font color=&quot;#FFFFFF&quot;&gt;list_tasks(&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#FFFFFF&quot;&gt;    user = Depends(get_current_user),&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#FFFFFF&quot;&gt;    _ = Depends(require_owner)&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#FFFFFF&quot;&gt;):&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#FFFFFF&quot;&gt;    ...&lt;/font&gt;" vertex="1">
          <mxGeometry height="125" width="254" x="788" y="608" as="geometry" />
        </mxCell>
        <mxCell id="p4-label" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=14;fontStyle=1;fontColor=#1a1a2e;" value="4. Token 生命周期" vertex="1">
          <mxGeometry height="25" width="200" x="30" y="770" as="geometry" />
        </mxCell>
        <mxCell id="p4-access" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEF2FF;strokeColor=#4f46e5;arcSize=5;" value="" vertex="1">
          <mxGeometry height="80" width="230" x="40" y="805" as="geometry" />
        </mxCell>
        <mxCell id="p4-access-t" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontColor=#4f46e5;" value="&lt;b&gt;Access Token&lt;/b&gt;" vertex="1">
          <mxGeometry height="18" width="100" x="50" y="810" as="geometry" />
        </mxCell>
        <mxCell id="p4-access-d" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=9;fontColor=#6b7280;spacingLeft=6;" value="• 有效期: &lt;b&gt;30 分钟&lt;/b&gt;&lt;br&gt;• 存放: 内存 store + Authorization header&lt;br&gt;• 无状态 (不查 Redis)&lt;br&gt;• Payload: {sub: user_id, role, exp}" vertex="1">
          <mxGeometry height="50" width="210" x="50" y="830" as="geometry" />
        </mxCell>
        <mxCell id="p4-refresh" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0FDF4;strokeColor=#10b981;arcSize=5;" value="" vertex="1">
          <mxGeometry height="80" width="240" x="310" y="805" as="geometry" />
        </mxCell>
        <mxCell id="p4-refresh-t" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontColor=#10b981;" value="&lt;b&gt;Refresh Token&lt;/b&gt;" vertex="1">
          <mxGeometry height="18" width="110" x="320" y="810" as="geometry" />
        </mxCell>
        <mxCell id="p4-refresh-d" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=9;fontColor=#6b7280;spacingLeft=6;" value="• 有效期: &lt;b&gt;7 天&lt;/b&gt;&lt;br&gt;• 存放: localStorage + Redis 白名单 (jti)&lt;br&gt;• 每次刷新: 旧 jti 出白名单, 新 jti 入白名单&lt;br&gt;• 可吊销 (Redis DEL jti)" vertex="1">
          <mxGeometry height="50" width="220" x="320" y="830" as="geometry" />
        </mxCell>
        <mxCell id="p4-rotate" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#f59e0b;arcSize=5;" value="" vertex="1">
          <mxGeometry height="80" width="230" x="590" y="805" as="geometry" />
        </mxCell>
        <mxCell id="p4-rotate-t" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontColor=#f59e0b;" value="&lt;b&gt;Token 轮换 (Rotation)&lt;/b&gt;" vertex="1">
          <mxGeometry height="18" width="170" x="600" y="810" as="geometry" />
        </mxCell>
        <mxCell id="p4-rotate-d" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=9;fontColor=#6b7280;spacingLeft=6;" value="• Access 过期 → 自动用 Refresh 换新&lt;br&gt;• 每次刷新同时换发新 Refresh&lt;br&gt;• 旧 Refresh 被标记失效&lt;br&gt;• 防止 Refresh Token 泄露后被长期利用" vertex="1">
          <mxGeometry height="50" width="210" x="600" y="830" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
