# LabelHub 环境变量
# 复制此文件为 .env 并填入实际值

# ── 数据库 ──
DB_HOST=
DB_PORT=10010
DB_USER=
DB_PASSWORD=
DB_NAME=labelhub

# ── Redis ──
REDIS_HOST=
REDIS_PORT=10001
REDIS_PASSWORD=
REDIS_DB=15

# ── RabbitMQ ──
MQ_HOST=
MQ_PORT=10030
MQ_USER=
MQ_PASSWORD=
MQ_VHOST=/

# ── LLM ──
LLM_API_KEY=
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_MODEL=doubao-seed-2-0-lite
# AI Agent 池最大并发数（默认 5）
AGENT_POOL_SIZE=5

# ── JWT ──
JWT_SECRET=

# ── 生产服务器 ──
# SSH 连接: ssh -i <key_path> root@<server_ip>
# API 地址: http://<server_ip>:8000
# API 文档: http://<server_ip>:8000/docs
# API_BASE_URL=http://<server_ip>:8000

# ── 脚本info ──
# 项目源码目录
PROJECT_SOURCE_CODE_DIRECTORY=XXXXX\Hongc-LabelHub
#赛程提交目录
CONTEST_SUBMISSION_DIRECTORY=XXXXX\submission
